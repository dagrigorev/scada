{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.SignalR": "Information",
        "System": "Warning"
      }
    }
  },
  "Realtime": {
    "BroadcastIntervalMs": 1000,
    "UseRedisBackplane": false,
    "RedisConnectionString": "localhost:6379"
  },
  "Jwt": {
    "SecretKey": "YourVerySecureSecretKeyMinimum32Characters!!ChangeThisInProduction",
    "Issuer": "RapidScada",
    "Audience": "RapidScadaClients"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=rapidscada;Username=scada;Password=scada123"
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5004"
      },
      "Https": {
        "Url": "https://localhost:5005"
      }
    }
  }
}
