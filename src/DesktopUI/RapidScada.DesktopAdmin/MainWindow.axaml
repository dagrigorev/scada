<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RapidScada.DesktopAdmin.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="RapidScada.DesktopAdmin.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="RapidSCADA - Desktop Administration"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="#111827">

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="#1f2937" BorderThickness="0,0,1,0" BorderBrush="#374151">
            <StackPanel>
                <!-- Header -->
                <Border Height="80" Background="#111827" Padding="20">
                    <StackPanel>
                        <TextBlock Text="RapidSCADA" FontSize="24" FontWeight="Bold" Foreground="#0ea5e9"/>
                        <TextBlock Text="Desktop Admin" FontSize="12" Foreground="#9ca3af"/>
                    </StackPanel>
                </Border>

                <!-- Navigation Items -->
                <StackPanel Margin="0,20,0,0">
                    <Button Content="Service Manager" 
                            Command="{Binding NavigateToServiceManagerCommand}"
                            Background="Transparent"
                            Foreground="#9ca3af"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="20,12"
                            Margin="8,2"/>
                    
                    <Button Content="Database Manager" 
                            Command="{Binding NavigateToDatabaseManagerCommand}"
                            Background="Transparent"
                            Foreground="#9ca3af"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="20,12"
                            Margin="8,2"/>
                    
                    <Button Content="Configuration" 
                            Command="{Binding NavigateToConfigurationCommand}"
                            Background="Transparent"
                            Foreground="#9ca3af"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="20,12"
                            Margin="8,2"/>
                    
                    <Button Content="Diagnostics" 
                            Command="{Binding NavigateToDiagnosticsCommand}"
                            Background="Transparent"
                            Foreground="#9ca3af"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="20,12"
                            Margin="8,2"/>
                    
                    <Button Content="System Logs" 
                            Command="{Binding NavigateToLogsCommand}"
                            Background="Transparent"
                            Foreground="#9ca3af"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="20,12"
                            Margin="8,2"/>
                </StackPanel>

                <!-- Language Switcher -->
                <StackPanel Margin="20" VerticalAlignment="Bottom">
                    <TextBlock Text="Language / Язык" Foreground="#9ca3af" FontSize="11" Margin="0,0,0,5"/>
                    <ComboBox SelectedIndex="0">
                        <ComboBoxItem Content="English"/>
                        <ComboBoxItem Content="Русский"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Border Grid.Column="1" Background="#111827" Padding="20">
            <ScrollViewer>
                <ContentControl Content="{Binding CurrentView}"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
